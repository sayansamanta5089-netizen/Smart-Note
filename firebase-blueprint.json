{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with stats and preferences",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Unique user identifier"
        },
        "email": {
          "type": "string",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "User's avatar image URL"
        },
        "role": {
          "type": "string",
          "description": "User's role (user or admin)",
          "enum": ["user", "admin"]
        },
        "totalSummaries": {
          "type": "integer",
          "description": "Total number of summaries generated by user"
        },
        "readingTimeSaved": {
          "type": "number",
          "description": "Estimated reading time saved in hours"
        },
        "createdAt": {
          "type": "string",
          "description": "User registration timestamp"
        }
      },
      "required": ["userId", "email", "role"]
    },
    "Summary": {
      "title": "Summary",
      "description": "Generated AI Summary and enhanced note capabilities",
      "type": "object",
      "properties": {
        "summaryId": {
          "type": "string",
          "description": "Unique summary identifier"
        },
        "userId": {
          "type": "string",
          "description": "Owner of the summary"
        },
        "title": {
          "type": "string",
          "description": "AI generated title"
        },
        "originalText": {
          "type": "string",
          "description": "The original user note/content"
        },
        "fileType": {
          "type": "string",
          "description": "The type of file uploaded (text, pdf, docx, manual)",
          "enum": ["manual", "txt", "pdf", "docx"]
        },
        "fileName": {
          "type": "string",
          "description": "Name of the uploaded file if applicable"
        },
        "shortSummary": {
          "type": "string",
          "description": "Concise summary in 3-5 sentences"
        },
        "detailedSummary": {
          "type": "string",
          "description": "Detailed structured summary in markdown"
        },
        "language": {
          "type": "string",
          "description": "The language of the summary",
          "enum": ["en", "hi", "bn"]
        },
        "category": {
          "type": "string",
          "description": "Topic category metadata"
        },
        "sentiment": {
          "type": "string",
          "description": "Overall sentiment analysis outcome"
        },
        "difficulty": {
          "type": "string",
          "description": "Difficulty level detection of content",
          "enum": ["easy", "medium", "hard"]
        },
        "readingTime": {
          "type": "number",
          "description": "Reading time of original content in minutes"
        },
        "explainLikeIm5": {
          "type": "string",
          "description": "Simplified ELI5 explanation"
        },
        "keyPoints": {
          "type": "array",
          "description": "Extracted key bullet points"
        },
        "actionItems": {
          "type": "array",
          "description": "Detected action items, tasks, and deadlines"
        },
        "studyNotes": {
          "type": "string",
          "description": "Exam-ready study notes content"
        },
        "questions": {
          "type": "array",
          "description": "Generated study questions / quiz MCQs"
        },
        "flashcards": {
          "type": "array",
          "description": "Generated revision flashcards"
        },
        "mindMap": {
          "type": "object",
          "description": "Hierarchical mind map data generator outcome"
        },
        "isBookmarked": {
          "type": "boolean",
          "description": "Whether this summary is bookmarked by user"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of summary generation"
        },
        "wordCount": {
          "type": "integer",
          "description": "Word count of original text"
        },
        "charCount": {
          "type": "integer",
          "description": "Character count of original text"
        }
      },
      "required": ["summaryId", "userId", "title", "originalText", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/summaries/{summaryId}": {
      "schema": "Summary",
      "description": "AI summaries created by the user"
    }
  }
}
